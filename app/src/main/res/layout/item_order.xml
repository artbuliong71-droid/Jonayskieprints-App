<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Row 1: Order ID + Service  |  Amount (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_order_id_service"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="#------  —  Print"
                android:textColor="#111827"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Amount (right-aligned, bold) -->
            <TextView
                android:id="@+id/tv_order_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textColor="#111827"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Row 2: Customer name  |  Status badge (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="3dp">

            <TextView
                android:id="@+id/tv_customer_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Customer Name"
                android:textColor="#374151"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_pending"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="pending"
                android:textColor="#92400E"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Row 3: Qty + Payment badge + Pickup time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_qty_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Qty: 1"
                android:textColor="#6B7280"
                android:textSize="11sp" />

            <!-- Payment method badge: Cash / GCash -->
            <TextView
                android:id="@+id/tv_payment_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_badge_pickup"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="Cash"
                android:textColor="#7C3AED"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_pickup_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_badge_pickup"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="🕐 5:00 PM"
                android:textColor="#7C3AED"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Date (pushed to end) -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_order_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jan 1, 2025"
                android:textColor="#9CA3AF"
                android:textSize="10sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Row 4: Specs preview -->
        <TextView
            android:id="@+id/tv_specs_preview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="..."
            android:textColor="#6B7280"
            android:textSize="11sp" />

        <!-- Row 5: Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btn_view_details"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginEnd="4dp"
                android:minHeight="0dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="0dp"
                android:text="VIEW DETAILS"
                android:textColor="#2563EB"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_edit_order"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginEnd="4dp"
                android:minHeight="0dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="0dp"
                android:text="EDIT"
                android:textColor="#7C3AED"
                android:textSize="11sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_cancel_order"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:minHeight="0dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="0dp"
                android:text="CAN"
                android:textColor="#EF4444"
                android:textSize="11sp"
                android:visibility="gone" />

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Admin-only: Status Spinner -->
            <Spinner
                android:id="@+id/spinner_status"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_badge_pending"
                android:paddingHorizontal="8dp"
                android:visibility="gone" />

            <!-- Admin-only: Delete button -->
            <ImageButton
                android:id="@+id/btn_delete_order"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_badge_cancelled"
                android:contentDescription="Delete order"
                android:padding="4dp"
                android:src="@drawable/ic_delete"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>