<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:padding="18dp">

    <!-- Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp">

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_badge_gcash">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_grid"
                app:tint="#7C3AED" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GCash Receipt"
                android:textColor="#111827"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_gcash_order_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order #------"
                android:textColor="#6B7280"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Ref Number Box -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_badge_pickup"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:letterSpacing="0.06"
                android:text="GCASH REFERENCE NUMBER"
                android:textAllCaps="true"
                android:textColor="#7C3AED"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_ref_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="000000000000"
                android:textColor="#111827"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/circle_green"
            android:src="@drawable/ic_check"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!-- Amount Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F9FAFB"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal"
        android:padding="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Amount Paid"
            android:textColor="#6B7280"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_gcash_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₱0.00"
            android:textColor="#7C3AED"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Receipt Image -->
    <ImageView
        android:id="@+id/iv_receipt"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="#F3F4F6"
        android:contentDescription="GCash receipt"
        android:scaleType="fitCenter"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_no_receipt"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="center"
        android:text="No receipt image uploaded."
        android:textColor="#9CA3AF"
        android:textSize="13sp"
        android:visibility="visible" />

    <!-- Close Button -->
    <Button
        android:id="@+id/btn_close_gcash"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:text="Close"
        app:strokeColor="@color/colorPrimary" />

</LinearLayout>
