<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_header_gradient">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_list"
                        android:tint="@android:color/white" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_detail_order_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/order_number_prefix"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_detail_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#9CA3AF"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_detail_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="×"
                android:textColor="#6B7280"
                android:textSize="26sp"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Status banner -->
        <LinearLayout
            android:id="@+id/ll_status_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_pending"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:padding="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/status_label_pending"
                android:textColor="#92400E"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_detail_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_pending"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/status_pending"
                android:textColor="#92400E"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Service details table -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/label_service_details"
            android:textColor="#9CA3AF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.07" />

        <LinearLayout
            android:id="@+id/ll_detail_rows"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_spinner"
            android:layout_marginBottom="12dp"
            android:orientation="vertical" />

        <!-- Specifications -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/label_specifications"
            android:textColor="#9CA3AF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.07" />

        <TextView
            android:id="@+id/tv_detail_specs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_spinner"
            android:layout_marginBottom="12dp"
            android:lineSpacingExtra="4dp"
            android:padding="12dp"
            android:textColor="#374151"
            android:textSize="13sp" />

        <!-- Price breakdown -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/label_price_breakdown"
            android:textColor="#9CA3AF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.07" />

        <LinearLayout
            android:id="@+id/ll_price_breakdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_spinner"
            android:layout_marginBottom="12dp"
            android:orientation="vertical" />

        <!-- Payment method -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_spinner"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_payment_method"
                android:textColor="#6B7280"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_detail_payment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#111827"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Uploaded files -->
        <TextView
            android:id="@+id/tv_files_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/label_uploaded_files"
            android:textColor="#9CA3AF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.07"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/ll_detail_files"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:visibility="gone" />

        <!-- GCash receipt -->
        <TextView
            android:id="@+id/tv_receipt_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/label_gcash_receipt"
            android:textColor="#9CA3AF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.07"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/iv_detail_receipt"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="12dp"
            android:background="#F3F4F6"
            android:contentDescription="@string/desc_gcash_receipt"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <!-- Action buttons -->
        <LinearLayout
            android:id="@+id/ll_detail_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btn_detail_edit"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/btn_edit_order"
                android:visibility="gone"
                app:strokeColor="@color/colorAccent" />

            <Button
                android:id="@+id/btn_detail_cancel"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:backgroundTint="#EF4444"
                android:text="@string/btn_cancel_order"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_detail_close"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/close"
                app:strokeColor="@color/colorPrimary" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>