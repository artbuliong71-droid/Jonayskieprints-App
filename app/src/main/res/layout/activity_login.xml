<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_login.xml
    Converted from: LoginPage.tsx (Jonayskie Prints)

    Design notes:
    • Full-screen gradient background: #5B6DEE → #7C3AED → #A855F7
    • White card centered with logo, email/password fields, Google sign-in
    • Purple accent (#7C3AED) for buttons and focus states
    • "Back to Home" link below card
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:minHeight="600dp"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingVertical="32dp">

        <!-- ── White Card ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="28dp"
                android:paddingHorizontal="24dp"
                android:paddingTop="20dp">

                <!-- ── Logo ── -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="2dp">

                    <ImageView
                        android:id="@+id/iv_logo"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:contentDescription="Jonayskie Prints"
                        android:scaleType="fitCenter"
                        android:src="@drawable/logo" />
                </FrameLayout>

                <!-- ── Header text ── -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Welcome!"
                    android:textColor="#111827"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.03"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginBottom="20dp"
                    android:text="Sign in to your account to manage your orders"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp" />

                <!-- ── Email field ── -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"
                    android:letterSpacing="0.04"
                    android:text="EMAIL ADDRESS"
                    android:textAllCaps="true"
                    android:textColor="#374151"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_email"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxStrokeColor="#E5E7EB"
                    app:boxStrokeWidth="1.5dp"
                    app:errorEnabled="true"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="#9CA3AF">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints="emailAddress"
                        android:hint="you@example.com"
                        android:inputType="textEmailAddress"
                        android:paddingVertical="14dp"
                        android:textColor="#111827"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── Password field ── -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"
                    android:letterSpacing="0.04"
                    android:text="PASSWORD"
                    android:textAllCaps="true"
                    android:textColor="#374151"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_password"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxStrokeColor="#E5E7EB"
                    app:boxStrokeWidth="1.5dp"
                    app:endIconMode="password_toggle"
                    app:errorEnabled="true"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="#9CA3AF">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints="password"
                        android:hint="••••••••"
                        android:inputType="textPassword"
                        android:paddingVertical="14dp"
                        android:textColor="#111827"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── Remember me + Forgot password row ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal">

                    <!-- Remember me checkbox -->
                    <LinearLayout
                        android:id="@+id/ll_remember"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="4dp">

                        <!-- Custom purple checkbox -->
                        <FrameLayout
                            android:id="@+id/fl_checkbox"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_checkbox_unchecked">

                            <ImageView
                                android:id="@+id/iv_check"
                                android:layout_width="10dp"
                                android:layout_height="8dp"
                                android:layout_gravity="center"
                                android:contentDescription="Checked"
                                android:src="@drawable/ic_check_white"
                                android:visibility="gone" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Remember me"
                            android:textColor="#4B5563"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Forgot password -->
                    <TextView
                        android:id="@+id/tv_forgot_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="4dp"
                        android:text="Forgot Password?"
                        android:textColor="#7C3AED"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- ── Sign In button ── -->
                <Button
                    android:id="@+id/btn_sign_in"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="14dp"
                    android:backgroundTint="@null"
                    android:background="@drawable/bg_btn_gradient"
                    android:elevation="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02"
                    android:text="Sign In"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- ── Divider: or continue with ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:text="or continue with"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB" />
                </LinearLayout>

                <!-- ── Google Sign-In button ── -->
                <Button
                    android:id="@+id/btn_google"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_btn_white"
                    android:fontFamily="sans-serif-medium"
                    android:text="  Continue with Google"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_google"
                    app:iconGravity="textStart"
                    app:iconSize="18dp"
                    app:iconTint="@null"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1.5dp" />

                <!-- ── Divider: Don't have an account? ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:text="Don't have an account?"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB" />
                </LinearLayout>

                <!-- ── Create Account button ── -->
                <Button
                    android:id="@+id/btn_register"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Create Account"
                    android:textColor="#7C3AED"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:strokeColor="#C4B5FD"
                    app:strokeWidth="1.5dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
