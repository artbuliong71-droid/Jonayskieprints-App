<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Row 1: Order ID + Amount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tv_order_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="#------"
                android:textColor="#7C3AED"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_order_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textColor="#111827"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Row 2: Customer name + email -->
        <TextView
            android:id="@+id/tv_customer_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Customer Name"
            android:textColor="#111827"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_customer_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="email@example.com"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <!-- Row 3: Service + Qty -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tv_service"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Print B&amp;W"
                android:textColor="#374151"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_qty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Qty: 1"
                android:textColor="#6B7280"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Row 4: Payment badge + Pickup badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_payment_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_badge_gcash"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="GCash"
                android:textColor="#7C3AED"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_pickup_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_pickup"
                android:drawablePadding="3dp"
                android:paddingHorizontal="7dp"
                android:paddingVertical="3dp"
                android:text="🕐 5:00 PM"
                android:textColor="#7C3AED"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Row 5: Status chip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tv_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_badge_pending"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="pending"
                android:textColor="#92400E"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="Jan 1, 2025"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6"
            android:layout_marginBottom="10dp"/>

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Status Selector -->
            <Spinner
                android:id="@+id/spinner_status"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_spinner"
                android:paddingHorizontal="8dp"
                android:visibility="visible" />

            <Button
                android:id="@+id/btn_view_details"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="4dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="0dp"
                android:text="Details"
                android:textSize="11sp"
                app:strokeColor="@color/colorPrimary" />

            <Button
                android:id="@+id/btn_view_files"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="4dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="0dp"
                android:text="Files"
                android:textSize="11sp"
                app:strokeColor="#7C3AED" />

            <ImageButton
                android:id="@+id/btn_delete_order"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_btn_danger"
                android:contentDescription="Delete"
                android:src="@drawable/ic_trash"
                app:tint="@android:color/white" />
        </LinearLayout>

        <!-- GCash Receipt button (shown only for GCash orders) -->
        <Button
            android:id="@+id/btn_gcash_receipt"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="6dp"
            android:minHeight="0dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="0dp"
            android:text="GCash Receipt"
            android:textSize="11sp"
            android:visibility="gone"
            app:strokeColor="#7C3AED" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
